#### 10c. Total richness and Shannon diversity ###################
#### This is one row per site × year.
#### total_richness includes all taxa, including unknown alien status.
#### Shannon uses abundance summed per taxon.
site_diversity_base <- community_taxon_df %>%
  group_by(
    site_id,
    sample_year,
    HYBAS_ID,
    country,
    method) %>%
  summarise(
    total_richness = n_distinct(taxon),
    
    shannon = vegan::diversity(
      abundance_taxon,
      index = "shannon"),
    
    total_abundance = sum(abundance_taxon, na.rm = TRUE),
    
    n_native_taxa = n_distinct(taxon[alien_status == "native"]),
    n_non_native_taxa = n_distinct(taxon[alien_status == "non_native"]),
    n_unknown_taxa = n_distinct(taxon[alien_status == "unknown"]),
    
    .groups = "drop") %>%
  mutate(
    total_known_taxa = n_native_taxa + n_non_native_taxa,
    
    prop_unknown_taxa = if_else(
      total_richness > 0,
      n_unknown_taxa / total_richness,
      NA_real_))


#### 10d. Proportion of non-native taxa ##########################
#### This is the main non-native response.
#### It is based on number of taxa/species, not abundance.
site_prop_base <- site_diversity_base %>%
  transmute(
    site_id,
    sample_year,
    HYBAS_ID,
    country,
    method,
    
    native_taxa = n_native_taxa,
    non_native_taxa = n_non_native_taxa,
    unknown_taxa = n_unknown_taxa,
    total_known_taxa,
    total_richness,
    
    prop_non_native_taxa = if_else(
      total_known_taxa > 0,
      non_native_taxa / total_known_taxa,
      NA_real_),
    
    prop_unknown_taxa) %>%
  filter(total_known_taxa > 0)


#### 10e. Optional abundance-based non-native proportion #########
#### This is NOT the main response.
#### It is useful later as a sensitivity check if needed.
site_abundance_prop_base <- community_taxon_df %>%
  group_by(
    site_id,
    sample_year,
    HYBAS_ID,
    country,
    method) %>%
  summarise(
    native_abundance = sum(
      abundance_taxon[alien_status == "native"],
      na.rm = TRUE),
    
    non_native_abundance = sum(
      abundance_taxon[alien_status == "non_native"],
      na.rm = TRUE),
    
    unknown_abundance = sum(
      abundance_taxon[alien_status == "unknown"],
      na.rm = TRUE),
    
    .groups = "drop") %>%
  mutate(
    total_known_abundance = native_abundance + non_native_abundance,
    
    prop_non_native_abundance = if_else(
      total_known_abundance > 0,
      non_native_abundance / total_known_abundance,
      NA_real_))


#### 10f. Long-format data for richness and Shannon models #######
#### This lets you fit richness and Shannon with the same joining code later.
#### response = "total_richness" or "shannon"
#### value = response value
site_response_long <- site_diversity_base %>%
  select(
    site_id,
    sample_year,
    HYBAS_ID,
    country,
    method,
    total_richness,
    shannon,
    total_abundance,
    n_native_taxa,
    n_non_native_taxa,
    n_unknown_taxa,
    total_known_taxa,
    prop_unknown_taxa) %>%
  pivot_longer(
    cols = c(total_richness, shannon),
    names_to = "response",
    values_to = "value") %>%
  mutate(
    response = factor(
      response,
      levels = c("total_richness", "shannon")))


