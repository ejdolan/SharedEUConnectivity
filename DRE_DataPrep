  ungroup() %>%
  rename(
    closest_removed_AMBER_ID = AMBER_ID,
    closest_removed_removal_id = matched_removal_id,
    closest_removed_year = YearRemoved,
    closest_removed_distance_m = community_amber_distance_m,
    closest_removed_distance_km = community_amber_distance_km,
    closest_removed_barrier_rank = barrier_rank_from_community
  )

closest_overall_barrier_by_sample <- community_amber_rankings %>%
  group_by(community_id) %>%
  slice_min(
    order_by = community_amber_distance_m,
    n = 1,
    with_ties = FALSE
  ) %>%
  ungroup() %>%
  transmute(
    community_id,
    closest_overall_AMBER_ID = AMBER_ID,
    closest_overall_type = amber_type_reduced,
    closest_overall_distance_m = community_amber_distance_m,
    closest_overall_was_removed = was_removed,
    closest_overall_removed_year = YearRemoved
  )

community_samples_with_closest <- community_position_df %>%
  st_drop_geometry() %>%
  left_join(
    closest_overall_barrier_by_sample,
    by = "community_id"
  ) %>%
  left_join(
    closest_removed_barrier_by_sample %>%
      select(
        community_id,
        closest_removed_AMBER_ID,
        closest_removed_removal_id,
        closest_removed_year,
        closest_removed_distance_m,
        closest_removed_distance_km,
        closest_removed_barrier_rank,
        removal_type_reduced,
        amber_dre_type_match
      ),
    by = "community_id"
  )

write_csv(
  community_samples_with_closest,
  file.path(out_dir, "community_samples_with_closest_barrier_status.csv")
)

saveRDS(
  community_samples_with_closest,
  file.path(out_dir, "community_samples_with_closest_barrier_status.rds")
)


#### 13. Build consecutive sample intervals ######################
#### Each row is:
####   site_id previous sample year -> current sample year
####
#### Then identify removals that happened between those samples.

community_intervals <- community_samples_with_closest %>%
  arrange(site_id, sample_year) %>%
  group_by(site_id) %>%
  mutate(
    pre_community_id = lag(community_id),
    pre_year = lag(sample_year),
    pre_total_richness = lag(total_richness),
    pre_shannon = lag(shannon),
    pre_prop_non_native = lag(prop_non_native),
    pre_total_known_taxa = lag(total_known_taxa),
    pre_n_non_native_taxa = lag(n_non_native_taxa),
    
    post_community_id = community_id,
    post_year = sample_year,
    post_total_richness = total_richness,
    post_shannon = shannon,
    post_prop_non_native = prop_non_native,
    post_total_known_taxa = total_known_taxa,
    post_n_non_native_taxa = n_non_native_taxa
  ) %>%
  ungroup() %>%
  filter(!is.na(pre_year), post_year > pre_year) %>%
  select(
    site_id,
    country,
    method,
    HYBAS_ID,
    HYRIV_ID,
    MAIN_RIV,
    pre_community_id,
    post_community_id,
    pre_year,
    post_year,
    pre_total_richness,
    post_total_richness,
    pre_shannon,
    post_shannon,
    pre_prop_non_native,
    post_prop_non_native,
    pre_total_known_taxa,
    post_total_known_taxa,
    pre_n_non_native_taxa,
    post_n_non_native_taxa
  )

#### Candidate removal events for each site.
#### We use the community-barrier rankings but collapse to site-level because
#### a site may have multiple sample years.

site_removed_barriers <- community_amber_rankings %>%
  filter(was_removed) %>%
  group_by(
    site_id,
    AMBER_ID,
    matched_removal_id,
    YearRemoved,
    removal_type_reduced
  ) %>%
  summarise(
    min_distance_m = min(community_amber_distance_m, na.rm = TRUE),
    best_rank_observed = min(barrier_rank_from_community, na.rm = TRUE),
    HYRIV_ID = first(HYRIV_ID),
    MAIN_RIV = first(MAIN_RIV),
    .groups = "drop"
  ) %>%
  arrange(site_id, YearRemoved, min_distance_m)

interval_removal_events <- community_intervals %>%
  left_join(
    site_removed_barriers,
    by = c("site_id", "HYRIV_ID", "MAIN_RIV"),
    relationship = "many-to-many"
  ) %>%
  filter(
    !is.na(YearRemoved),
    YearRemoved > pre_year,
    YearRemoved <= post_year
  ) %>%
  group_by(site_id, pre_year, post_year) %>%
  mutate(
    n_removals_in_interval = n_distinct(matched_removal_id),
    closest_removed_in_interval_m =
      min(min_distance_m, na.rm = TRUE)
  ) %>%
  arrange(site_id, pre_year, post_year, min_distance_m) %>%
  ungroup()

closest_removed_barrier_intervals <- interval_removal_events %>%
  group_by(site_id, pre_year, post_year) %>%
  slice_min(
    order_by = min_distance_m,
    n = 1,
    with_ties = FALSE
  ) %>%
  ungroup() %>%
  mutate(
    single_removal_interval = n_removals_in_interval == 1,
    multiple_removals_interval = n_removals_in_interval > 1,
    years_between_samples = post_year - pre_year,
    years_removal_after_pre = YearRemoved - pre_year,
    years_post_after_removal = post_year - YearRemoved
  )

write_csv(
  closest_removed_barrier_intervals,
  file.path(out_dir, "closest_removed_barrier_intervals.csv")
)

saveRDS(
  closest_removed_barrier_intervals,
  file.path(out_dir, "closest_removed_barrier_intervals.rds")
)


#### 14. Effect sizes: pre sample to first post sample ############
#### This version does NOT rely on safe_diff() or safe_log_ratio()
closest_removed_barrier_effect_sizes <- closest_removed_barrier_intervals %>%
  mutate(
    effect_total_richness_diff =
      post_total_richness - pre_total_richness,
    
    effect_total_richness_lnRR =
      log((post_total_richness + 0.5) / (pre_total_richness + 0.5)),
    
    effect_shannon_diff =
      post_shannon - pre_shannon,
    
    effect_shannon_lnRR =
      log((post_shannon + 0.01) / (pre_shannon + 0.01)),
    
    effect_prop_non_native_diff =
      post_prop_non_native - pre_prop_non_native,
    
    effect_non_native_count_diff =
      post_n_non_native_taxa - pre_n_non_native_taxa,
    
    event_id = paste(
      site_id,
      matched_removal_id,
      pre_year,
      post_year,
      sep = "_"
    )
  )

write_csv(
  closest_removed_barrier_effect_sizes,
  file.path(out_dir, "closest_removed_barrier_effect_sizes.csv")
)

saveRDS(
  closest_removed_barrier_effect_sizes,
  file.path(out_dir, "closest_removed_barrier_effect_sizes.rds")
)

cat("\nEffect-size dataset created and saved.\n")
cat("Rows:", nrow(closest_removed_barrier_effect_sizes), "\n")


#### 15. Recovery trajectories ###################################
#### For every site-removal event, keep all community samples after
#### removal until the next removal at that site.
####
#### This lets you model recovery through time since removal.
#### If another removal occurs, the previous recovery trajectory is censored.
site_removal_events <- site_removed_barriers %>%
  arrange(site_id, YearRemoved, min_distance_m) %>%
  group_by(site_id) %>%
  mutate(
    removal_event_order = row_number(),
    next_removal_year = lead(YearRemoved),
    previous_removal_year = lag(YearRemoved),
    cumulative_removals_before = row_number() - 1
  ) %>%
  ungroup() %>%
  mutate(
    removal_event_id = paste(site_id, matched_removal_id, YearRemoved, sep = "_")
  )

recovery_trajectories <- site_removal_events %>%
  select(
    site_id,
    removal_event_id,
    matched_removal_id,
    AMBER_ID,
    YearRemoved,
    removal_type_reduced,
    min_distance_m,
    best_rank_observed,
    removal_event_order,
    previous_removal_year,
    next_removal_year,
    cumulative_removals_before
  ) %>%
  left_join(
    community_samples_with_closest %>%
      select(
        site_id,
        community_id,
        sample_year,
        country,
        method,
        HYBAS_ID,
        HYRIV_ID,
        MAIN_RIV,
        total_richness,
        shannon,
        prop_non_native,
        total_known_taxa,
        n_non_native_taxa
      ),
    by = "site_id",
    relationship = "many-to-many"
  ) %>%
  mutate(
    years_since_removal = sample_year - YearRemoved,
    before_after = case_when(
      years_since_removal < 0 ~ "before",
      years_since_removal == 0 ~ "year_of_removal",
      years_since_removal > 0 ~ "after"
    ),
    censored_by_next_removal = !is.na(next_removal_year) &
      sample_year >= next_removal_year
  ) %>%
  filter(
    sample_year >= YearRemoved,
    is.na(next_removal_year) | sample_year < next_removal_year
  ) %>%
  arrange(site_id, removal_event_order, sample_year)

write_csv(
  recovery_trajectories,
  file.path(out_dir, "closest_removed_barrier_recovery_trajectories.csv")
)

saveRDS(
  recovery_trajectories,
  file.path(out_dir, "closest_removed_barrier_recovery_trajectories.rds")
)


#### 16. Summaries ###############################################
summary_event_data <- list(
  
  amber_dre_matching = list(
    n_dre_removals_snapped = n_distinct(dre_position_df$removal_id),
    n_amber_barriers_snapped = n_distinct(amber_position_df$AMBER_ID),
    n_dre_matched_to_amber_within_1km =
      n_distinct(amber_dre_best_match$removal_id),
    n_removed_amber_barriers =
      n_distinct(removed_amber_barriers$AMBER_ID)
  ),
  
  closest_barrier_status = community_samples_with_closest %>%
    summarise(
      n_community_samples = n(),
      n_with_closest_overall_barrier =
        sum(!is.na(closest_overall_AMBER_ID)),
      n_where_closest_overall_was_removed =
        sum(closest_overall_was_removed, na.rm = TRUE),
      n_with_any_removed_barrier =
        sum(!is.na(closest_removed_AMBER_ID)),
      median_rank_of_closest_removed_barrier =
        median(closest_removed_barrier_rank, na.rm = TRUE)
    ),
  
  event_intervals = closest_removed_barrier_effect_sizes %>%
    summarise(
      n_effect_size_events = n(),
      n_sites = n_distinct(site_id),
      n_removals = n_distinct(matched_removal_id),
      n_single_removal_intervals = sum(single_removal_interval),
      n_multiple_removal_intervals = sum(multiple_removals_interval),
      median_years_between_samples =
        median(years_between_samples, na.rm = TRUE),
      median_years_post_after_removal =
        median(years_post_after_removal, na.rm = TRUE)
    ),
  
  events_by_type = closest_removed_barrier_effect_sizes %>%
    count(removal_type_reduced, sort = TRUE),
  
  recovery = recovery_trajectories %>%
    summarise(
      n_recovery_rows = n(),
      n_sites = n_distinct(site_id),
      n_removal_events = n_distinct(removal_event_id),
      max_years_since_removal = max(years_since_removal, na.rm = TRUE),
      median_years_since_removal = median(years_since_removal, na.rm = TRUE)
    )
)

saveRDS(
  summary_event_data,
  file.path(out_dir, "summary_event_data_list.rds")
)

cat("\n--- AMBER-DRE matching summary ---\n")
print(summary_event_data$amber_dre_matching)

