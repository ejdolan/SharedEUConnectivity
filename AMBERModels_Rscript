#### 7. Priors ---------------------------------------------------

priors_richness <- c(
  prior(normal(0, 0.5), class = "b"),
  prior(normal(1, 1), class = "Intercept"),
  prior(exponential(1), class = "sd"),
  prior(exponential(1), class = "shape")
)

priors_prop <- c(
  prior(normal(0, 0.5), class = "b"),
  prior(normal(0, 1), class = "Intercept"),
  prior(exponential(1), class = "sd")
)


#### 8. Model formulae -------------------------------------------

# Richness is modelled separately for native and non-native
# community groups. The three-way interaction tests whether the
# relationship with barrier density differs among community groups
# and barrier types.

form_richness <- bf(
  value ~
    community_group * z_barrier_density * barrier_type_reduced +
    z_dist_up +
    z_dist_down +
    z_dist_mouth +
    z_log_population_density +
    z_mean_temp_annual +
    z_precip_annual +
    z_log_river_km +
    (1 | country) +
    (1 | HYBAS_ID) +
    (1 | site_id) +
    (1 | method) +
    (1 | sample_year)
)


# The response is the number of non-native taxa out of the total
# number of taxa with known native status.

form_prop <- bf(
  non_native | trials(total_taxa) ~
    z_barrier_density * barrier_type_reduced +
    z_dist_up +
    z_dist_down +
    z_dist_mouth +
    z_log_population_density +
    z_mean_temp_annual +
    z_precip_annual +
    z_log_river_km +
    (1 | country) +
    (1 | HYBAS_ID) +
    (1 | site_id) +
    (1 | method) +
    (1 | sample_year)
)


#### 9. MCMC settings --------------------------------------------

# These are first-pass settings.
# Increase adapt_delta or max_treedepth only if diagnostics require it.

chains_use        <- 4
cores_use         <- 4
iter_use          <- 4000
warmup_use        <- 1000
thin_use          <- 1
adapt_delta_use   <- 0.95
max_treedepth_use <- 12


#### 10. Fit richness model --------------------------------------

m_invert_richness_final <- brm(
  formula = form_richness,
  data = richness_data,
  family = negbinomial(),
  prior = priors_richness,

  chains = chains_use,
  cores = cores_use,
  iter = iter_use,
  warmup = warmup_use,
  thin = thin_use,

  seed = 1201,
  refresh = 100,

  control = list(
    adapt_delta = adapt_delta_use,
    max_treedepth = max_treedepth_use
  ),

  save_pars = save_pars(all = TRUE),

  file = file.path(
    out_dir,
    "m_invert_richness_final"
  ),

  file_refit = "on_change"
)


#### 11. Fit proportion non-native model -------------------------

# beta_binomial2() allows greater variation than a standard
# binomial model.

m_invert_prop_final <- brm(
  formula = form_prop,
  data = prop_data,
  family = beta_binomial2(),
  prior = priors_prop,

  chains = chains_use,
  cores = cores_use,
  iter = iter_use,
  warmup = warmup_use,
  thin = thin_use,

  seed = 1202,
  refresh = 100,

  control = list(
    adapt_delta = adapt_delta_use,
    max_treedepth = max_treedepth_use
  ),

  save_pars = save_pars(all = TRUE),

  file = file.path(
    out_dir,
    "m_invert_prop_final"
  ),

  file_refit = "on_change"
)


