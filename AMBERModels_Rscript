)

prop_required <- c(
  "non_native",
  "total_taxa",
  "barrier_type_reduced",
  "z_barrier_density",
  "z_dist_up",
  "z_dist_down",
  "z_dist_mouth",
  "z_log_population_density",
  "z_mean_temp_annual",
  "z_precip_annual",
  "z_log_river_km",
  "country",
  "HYBAS_ID",
