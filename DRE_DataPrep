#### 2. Manual along-line position function ######################
#### This avoids relying on st_line_locate_point(), which was not available
#### in your local lwgeom/sf setup.
####
#### It estimates the position of a point along its snapped HydroRIVERS
#### segment by projecting the point to the nearest piece of the line.

point_position_along_line <- function(line_geom, point_geom) {
  
  line_coords <- sf::st_coordinates(line_geom)
  point_coords <- sf::st_coordinates(point_geom)[1, c("X", "Y")]
  
  if ("L1" %in% colnames(line_coords)) {
    line_parts <- split(as.data.frame(line_coords), line_coords[, "L1"])
  } else {
    line_parts <- list(as.data.frame(line_coords))
  }
  
  best_dist_sq <- Inf
  best_distance_along <- NA_real_
  part_results <- list()
  
  for (part_i in seq_along(line_parts)) {
    
    coords <- line_parts[[part_i]]
    xy <- as.matrix(coords[, c("X", "Y")])
    
    if (nrow(xy) < 2) next
    
    seg_start <- xy[-nrow(xy), , drop = FALSE]
    seg_end <- xy[-1, , drop = FALSE]
    seg_vec <- seg_end - seg_start
    seg_len <- sqrt(rowSums(seg_vec^2))
    
    valid <- seg_len > 0
    
    if (!any(valid)) next
    
    seg_start <- seg_start[valid, , drop = FALSE]
    seg_vec <- seg_vec[valid, , drop = FALSE]
    seg_len <- seg_len[valid]
    
    cum_len_start <- c(0, cumsum(seg_len))[seq_along(seg_len)]
    
    px <- point_coords[["X"]]
    py <- point_coords[["Y"]]
    
    point_vec <- cbind(
      px - seg_start[, "X"],
      py - seg_start[, "Y"]
    )
    
    seg_len_sq <- seg_len^2
    
    t <- rowSums(point_vec * seg_vec) / seg_len_sq
    t <- pmax(0, pmin(1, t))
    
    proj <- seg_start + seg_vec * t
    
    dist_sq <- (px - proj[, "X"])^2 + (py - proj[, "Y"])^2
    
    best_seg <- which.min(dist_sq)
    
    part_results[[part_i]] <- list(
      part_length = sum(seg_len),
      best_dist_sq = dist_sq[best_seg],
      best_distance_along_part =
        cum_len_start[best_seg] + t[best_seg] * seg_len[best_seg]
    )
  }
  
  if (length(part_results) == 0) {
    return(
      tibble(
        line_fraction = NA_real_,
        line_distance_m = NA_real_
      )
    )
  }
  
  part_lengths <- purrr::map_dbl(part_results, "part_length")
  part_offsets <- c(0, cumsum(part_lengths))[seq_along(part_lengths)]
  
  for (part_i in seq_along(part_results)) {
    
    candidate_dist_sq <- part_results[[part_i]]$best_dist_sq
    candidate_distance_along <-
      part_offsets[part_i] + part_results[[part_i]]$best_distance_along_part
    
    if (candidate_dist_sq < best_dist_sq) {
      best_dist_sq <- candidate_dist_sq
      best_distance_along <- candidate_distance_along
    }
  }
  
  total_line_length <- sum(part_lengths)
  
  tibble(
    line_fraction = ifelse(
      total_line_length > 0,
      best_distance_along / total_line_length,
      NA_real_
    ),
    line_distance_m = best_distance_along
  )
}


add_position_along_segment <- function(points_sf, rivers_sf) {
  
  out_list <- vector("list", nrow(points_sf))
  
  for (i in seq_len(nrow(points_sf))) {
    
    h <- points_sf$HYRIV_ID[i]
    
    river_i <- rivers_sf %>%
      filter(HYRIV_ID == h)
    
    if (nrow(river_i) == 0) {
      out_list[[i]] <- st_drop_geometry(points_sf[i, ]) %>%
        mutate(
          line_fraction = NA_real_,
          line_distance_m = NA_real_
        )
      next
    }
    
    line_i <- st_geometry(river_i)[[1]]
    point_i <- st_geometry(points_sf[i, ])[[1]]
    
    pos_i <- point_position_along_line(line_i, point_i)
    
    out_list[[i]] <- st_drop_geometry(points_sf[i, ]) %>%
      mutate(
        line_fraction = pos_i$line_fraction,
        line_distance_m = pos_i$line_distance_m
      )
  }
  
  bind_rows(out_list)
}


