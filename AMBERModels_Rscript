prop_file <- file.path(
  data_dir,
  "invert_prop_final_barrier_type_reduced.rds"
)


#### 3. Load input data ------------------------------------------

richness_data <- readRDS(richness_file)
prop_data     <- readRDS(prop_file)


#### 4. Check required columns -----------------------------------

