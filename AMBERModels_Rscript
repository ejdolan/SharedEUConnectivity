#### 13. Save diagnostic summaries -------------------------------

summarise_model_diagnostics <- function(model, model_name) {
  draws <- as_draws(model)

  parameter_diagnostics <- summarise_draws(
    draws,
    rhat,
    ess_bulk,
    ess_tail
  )

  sampler_diagnostics <- nuts_params(model) %>%
    count(Parameter, Value)

  capture.output({
    cat(model_name, "\n")
    cat(strrep("=", nchar(model_name)), "\n\n")

    cat("Sampler diagnostics:\n")
    print(sampler_diagnostics)

    cat("\nParameter diagnostics:\n")
    print(parameter_diagnostics)

    cat("\nMaximum R-hat:\n")
    print(max(parameter_diagnostics$rhat, na.rm = TRUE))

    cat("\nMinimum bulk ESS:\n")
    print(min(parameter_diagnostics$ess_bulk, na.rm = TRUE))

    cat("\nMinimum tail ESS:\n")
    print(min(parameter_diagnostics$ess_tail, na.rm = TRUE))
  })
}

diagnostic_text <- c(
  summarise_model_diagnostics(
    m_invert_richness_final,
    "RICHNESS MODEL"
  ),
  "",
  "",
  summarise_model_diagnostics(
    m_invert_prop_final,
    "PROPORTION NON-NATIVE MODEL"
  )
)

writeLines(
