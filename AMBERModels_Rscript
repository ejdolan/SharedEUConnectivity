library(bayesplot)
library(ggplot2)

options(mc.cores = 4)
rstan::rstan_options(auto_write = TRUE)

set.seed(1200)


#### 2. File paths -----------------------------------------------

data_dir <- "Data/Processed/Final_Invert_Models"
