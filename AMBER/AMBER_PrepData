read_hyde_var <- function(var) {
  files <- list.files(
    "Data/HYDE/Processed",
    pattern = paste0("^", var, "_[0-9]{4}_[0-9]{4}\\.csv$"),
    full.names = TRUE)
  
  if (length(files) == 0) {
    stop("No HYDE processed files found for: ", var)
  }
  
  map_dfr(sort(files), read_csv, show_col_types = FALSE) %>%
    mutate(
      HYBAS_ID = as.character(HYBAS_ID),
      year = as.integer(year)) %>%
    distinct()
}

