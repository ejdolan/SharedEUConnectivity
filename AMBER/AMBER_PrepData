make_withouttype_diversity <- function(df) {
  
  df %>%
    mutate(
      site_id_chr = as.character(site_id),
      sample_year_chr = as.character(sample_year),
      HYBAS_ID_chr = as.character(HYBAS_ID),
      country_chr = as.character(country),
      method_chr = as.character(method)) %>%
    group_by(
      site_id_chr,
      sample_year_chr,
      HYBAS_ID_chr,
      country_chr,
      method_chr) %>%
    summarise(
      value = first(value),
      
      n_barrier_total = sum(n_barrier, na.rm = TRUE),
      barrier_density_total = sum(barrier_density, na.rm = TRUE),
      log_barrier_density_total = log1p(barrier_density_total),
      
      z_dist_up = first(z_dist_up),
      z_dist_down = first(z_dist_down),
      z_dist_mouth = first(z_dist_mouth),
      z_log_population_density = first(z_log_population_density),
      z_mean_temp_annual = first(z_mean_temp_annual),
      z_precip_annual = first(z_precip_annual),
      z_log_river_km = first(z_log_river_km),
      
      .groups = "drop") %>%
    mutate(
      z_barrier_density = z_safe(log_barrier_density_total),
      
      site_id = factor(site_id_chr),
      sample_year = factor(sample_year_chr),
      HYBAS_ID = factor(HYBAS_ID_chr),
      country = factor(country_chr),
      method = factor(method_chr)) %>%
    select(
      value,
      z_barrier_density,
      z_dist_up,
      z_dist_down,
      z_dist_mouth,
      z_log_population_density,
      z_mean_temp_annual,
      z_precip_annual,
      z_log_river_km,
      country,
      HYBAS_ID,
      site_id,
      method,
      sample_year,
      n_barrier_total,
      barrier_density_total,
      log_barrier_density_total) %>%
    filter(complete.cases(.)) %>%
    droplevels()
}


