  left_join(
    river_topo %>% select(HYRIV_ID, dist_mouth_km = DIST_DN_KM),
    by = "HYRIV_ID") %>%
  mutate(
    log_dist_up = log1p(dist_up_km),
    log_dist_down = log1p(dist_down_km),
    log_dist_mouth = log1p(dist_mouth_km))

