  "sample_year"
)

check_required_columns <- function(data, required_columns, data_name) {
  missing_columns <- setdiff(required_columns, names(data))

  if (length(missing_columns) > 0) {
    stop(
      data_name,
      " is missing these required columns: ",
      paste(missing_columns, collapse = ", ")
    )
  }
}

check_required_columns(
  richness_data,
  richness_required,
  "richness_data"
)

check_required_columns(
  prop_data,
  prop_required,
  "prop_data"
)


#### 5. Clean and format data ------------------------------------

richness_data <- richness_data %>%
  mutate(
    value = as.integer(value),

    community_group = relevel(
      factor(community_group),
      ref = "native"
    ),

    barrier_type_reduced = relevel(
      factor(barrier_type_reduced),
      ref = "other"
    ),

    country     = factor(country),
    HYBAS_ID    = factor(HYBAS_ID),
    site_id     = factor(site_id),
    method      = factor(method),
    sample_year = factor(sample_year)
  ) %>%
  filter(
    !is.na(value),
    value >= 0
  ) %>%
  droplevels()


prop_data <- prop_data %>%
  mutate(
    non_native = as.integer(non_native),
    total_taxa = as.integer(total_taxa),

    # Used only for data summaries and checks.
    prop_non_native = non_native / total_taxa,

    barrier_type_reduced = relevel(
      factor(barrier_type_reduced),
      ref = "other"
    ),

    country     = factor(country),
    HYBAS_ID    = factor(HYBAS_ID),
    site_id     = factor(site_id),
    method      = factor(method),
    sample_year = factor(sample_year)
  ) %>%
  filter(
    !is.na(non_native),
    !is.na(total_taxa),
    total_taxa > 0,
    non_native >= 0,
    non_native <= total_taxa
  ) %>%
  droplevels()


