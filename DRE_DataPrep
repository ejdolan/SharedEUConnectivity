#### 10. Match DRE removals to AMBER barriers ####################
#### A DRE removal is treated as corresponding to an AMBER barrier if:
####   - same HYRIV_ID
####   - within 1 km along the river segment
####
#### If more than one AMBER barrier matches a DRE removal, keep closest.

amber_dre_matches_all <- dre_position_df %>%
  select(
    removal_id,
    YearRemoved,
    removal_type,
    removal_type_reduced,
    DRE_HYBAS_ID = HYBAS_ID,
    HYRIV_ID,
    MAIN_RIV,
    dre_line_distance_m = line_distance_m,
    dre_dist_to_river_m = dist_to_river_m
  ) %>%
  inner_join(
    amber_position_df %>%
      select(
        AMBER_ID,
        amber_type,
        amber_type_reduced,
        AMBER_HYBAS_ID = HYBAS_ID,
        HYRIV_ID,
        amber_line_distance_m = line_distance_m,
        amber_dist_to_river_m = dist_to_river_m
      ),
    by = "HYRIV_ID",
    relationship = "many-to-many"
  ) %>%
  mutate(
    amber_dre_along_distance_m =
      abs(dre_line_distance_m - amber_line_distance_m),
    amber_dre_along_distance_km = amber_dre_along_distance_m / 1000,
    amber_dre_type_match =
      removal_type_reduced == amber_type_reduced
  ) %>%
  filter(amber_dre_along_distance_m <= 1000) %>%
  arrange(removal_id, amber_dre_along_distance_m)

amber_dre_best_match <- amber_dre_matches_all %>%
  group_by(removal_id) %>%
  slice_min(
    order_by = amber_dre_along_distance_m,
    n = 1,
    with_ties = FALSE
  ) %>%
  ungroup()

