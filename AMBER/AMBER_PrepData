#### 10. Community response data ################################
#### Final response variables:
####   1. total_richness
####   2. shannon
####   3. proportion of non-native taxa
####
#### Important decisions:
####   - total_richness = number of distinct taxa per site × year
####   - shannon = Shannon diversity using taxon abundances
####   - proportion non-native = non-native taxa / total known-status taxa
####   - unknown-status taxa are excluded from the denominator for proportion
####   - abundance is used for Shannon, but not for proportion non-native

#### 10a. Collapse to one row per taxon per community ############
#### Community = site_id × sample_year.
#### This prevents duplicate taxon rows from inflating richness.
community_taxon_df <- inverts_rivers_df %>%
  filter(
    !is.na(site_id),
    !is.na(sample_year),
    !is.na(HYBAS_ID),
    !is.na(taxon)) %>%
  mutate(
    abundance_num = suppressWarnings(as.numeric(abundance_num)),
    abundance_num = if_else(is.na(abundance_num), 0, abundance_num),
    alien_status = case_when(
      alien_status %in% c("native", "non_native") ~ alien_status,
      TRUE ~ "unknown")) %>%
  group_by(
    site_id,
    sample_year,
    HYBAS_ID,
    country,
    method,
    taxon) %>%
  summarise(
    abundance_taxon = sum(abundance_num, na.rm = TRUE),
    alien_status = first(na.omit(alien_status)),
    .groups = "drop") %>%
  mutate(
    alien_status = if_else(
      is.na(alien_status),
      "unknown",
      alien_status))


