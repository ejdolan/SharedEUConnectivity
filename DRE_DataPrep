snap_to_river <- function(points_sf, rivers_sf, threshold_m = 2000) {
  
  pts_3035 <- st_transform(points_sf, 3035)
  rivers_3035 <- st_transform(rivers_sf, 3035)
  
  nearest_idx <- st_nearest_feature(pts_3035, rivers_3035)
  
  dist_to_river_m <- as.numeric(
    st_distance(
      pts_3035,
      rivers_3035[nearest_idx, ],
      by_element = TRUE
    )
  )
  
  keep <- dist_to_river_m <= threshold_m
  
  out <- bind_cols(
    st_drop_geometry(pts_3035[keep, ]),
    st_drop_geometry(rivers_3035[nearest_idx[keep], ]) %>%
      select(HYRIV_ID, NEXT_DOWN, MAIN_RIV, LENGTH_KM, DIST_DN_KM)
  )
  
  out$dist_to_river_m <- dist_to_river_m[keep]
  
  st_as_sf(
    out,
    coords = c("Longitude_X", "Latitude_Y"),
    crs = 3035,
    remove = FALSE
  )
}

snap_barrier_to_river <- function(points_sf, rivers_sf, x_col, y_col, threshold_m = 2000) {
  
  pts_3035 <- st_transform(points_sf, 3035)
  rivers_3035 <- st_transform(rivers_sf, 3035)
  
  nearest_idx <- st_nearest_feature(pts_3035, rivers_3035)
  
  dist_to_river_m <- as.numeric(
    st_distance(
      pts_3035,
      rivers_3035[nearest_idx, ],
      by_element = TRUE
    )
  )
  
  keep <- dist_to_river_m <= threshold_m
  
  out <- bind_cols(
    st_drop_geometry(pts_3035[keep, ]),
    st_drop_geometry(rivers_3035[nearest_idx[keep], ]) %>%
      select(HYRIV_ID, NEXT_DOWN, MAIN_RIV, LENGTH_KM, DIST_DN_KM)
  )
  
  out$dist_to_river_m <- dist_to_river_m[keep]
  
  # use original projected geometry from snapped points
  st_as_sf(out, geometry = st_geometry(pts_3035[keep, ]), crs = 3035)
}

